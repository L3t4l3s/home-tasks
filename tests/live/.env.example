# Live test configuration — copy to tests/live/.env and fill in.
# tests/live/.env is gitignored.  Each variable is optional; tests that
# need it are auto-skipped if it's missing.

# ---------------------------------------------------------------------------
# WebSocket connection (required for ALL live tests)
# ---------------------------------------------------------------------------

# HA base URL.  Use http://supervisor/core when running inside the addon
# container, or http://homeassistant.local:8123 from the host network.
HT_HA_URL=http://homeassistant.local:8123

# Long-lived access token from Home Assistant → Profile → Security
HT_HA_TOKEN=

# ---------------------------------------------------------------------------
# Native test list (required for E2E WebSocket tests)
# ---------------------------------------------------------------------------

# Create a NEW empty Home Tasks native list named "Home-Tasks E2E Test"
# via Settings → Integrations → Home Tasks → Add list.
HT_NATIVE_LIST_NAME=Home-Tasks E2E Test

# Optional second native list (only needed for move_task tests)
HT_NATIVE_LIST_NAME_2=Home-Tasks E2E Test 2

# ---------------------------------------------------------------------------
# External provider test entities (each optional, test gets skipped if unset)
# ---------------------------------------------------------------------------

# For each provider, create a NEW empty list/project in the provider's UI:
#  - Todoist:    new project named e.g. "ht-test"
#  - Google:     new task list named e.g. "ht-test"
#  - CalDAV:     new collection named e.g. "ht-test"
#  - Local Todo: new local todo named e.g. "ht-test"
#  - Bring:      new shopping list named e.g. "ht-test"
#
# Then link each one through Home Tasks → Add external list.  Find the
# resulting entity_id under Settings → Devices & Services → Entities.

HT_TODOIST_TEST_ENTITY=todo.ht_test_todoist
HT_GOOGLE_TASKS_TEST_ENTITY=todo.ht_test_google
HT_CALDAV_TEST_ENTITY=todo.ht_test_nextcloud
HT_LOCAL_TODO_TEST_ENTITY=todo.ht_test_local
HT_BRING_TEST_ENTITY=todo.ht_test_bring

# ---------------------------------------------------------------------------
# Safety
# ---------------------------------------------------------------------------

# Maximum existing items in a test list before fixtures abort.  Protects
# against accidentally pointing tests at a non-test list.
HT_MAX_EXISTING_ITEMS=50
